generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  EVENTEE
}

model User {
  id        String   @id @default(uuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(EVENTEE)
  createdAt DateTime @default(now())

  events Event[]
  tickets Ticket[]
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  venue       String
  eventDate   DateTime
  ticketPrice Float

  creatorId String
  creator   User @relation(fields: [creatorId], references: [id])

  tickets Ticket[]

  createdAt DateTime @default(now())
}

model Ticket {
  id        String   @id @default(uuid())

  userId    String
  user      User @relation(fields: [userId], references: [id])

  eventId   String
  event     Event @relation(fields: [eventId], references: [id])

  qrCode    String?

  isScanned Boolean @default(false)

  createdAt DateTime @default(now())
}